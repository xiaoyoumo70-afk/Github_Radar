# GitHub token (optional, avoids rate limiting)
GITHUB_TOKEN=

# ── LLM Provider ──────────────────────────────────────────────
# Provider preset: local | openai | deepseek | custom
#   local    → Any OpenAI-compatible local endpoint (Ollama/vLLM/LM Studio)
#   openai   → api.openai.com (requires API key)
#   deepseek → api.deepseek.com (requires API key)
#   custom   → Use LLM_BASE_URL directly (for any OpenAI-compatible API)
LLM_PROVIDER=local

# Base URL (used when provider=custom, or to override preset)
LLM_BASE_URL=http://localhost:8000/v1

# Model name
LLM_MODEL=qwen3.7

# API key (required for openai/deepseek, optional for local/custom)
LLM_API_KEY=

# ── Obsidian ───────────────────────────────────────────────────
OBSIDIAN_VAULT=AI-Vault

# ── Storage ────────────────────────────────────────────────────
ARTIFACTS_DIR=artifacts

# ── Content limits ─────────────────────────────────────────────
MAX_README_CHARS=30000
MAX_FILE_CHARS=20000
CONTEXT_WARNING_CHARS=90000
